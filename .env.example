# =============================================================================
# RINEX Streaming - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This ONE file is used for BOTH manual run and Docker deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Data Source Configuration
# -----------------------------------------------------------------------------
SOURCE_HOST=api.simurg.space
SOURCE_PORT=443

# -----------------------------------------------------------------------------
# RabbitMQ Configuration
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=user
RABBITMQ_PASSWORD=123

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# IMPORTANT: This is the ONLY place where you set the storage path
# Docker will use this exact path inside containers

STORAGE_PATH=/root/projects/rinex_streaming/data

# Other settings
DAYS_TO_SUBTRACT=717
AVAILABLE_RAM=85

# -----------------------------------------------------------------------------
# API Server (Auto-configured by Docker, no need to change)
# -----------------------------------------------------------------------------
SERVER_URL=http://localhost:8000
