# =============================================================================
# RINEX Streaming - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file works for BOTH manual run and Docker deployment
# =============================================================================

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
# For manual run: http://localhost:8000
# For Docker: http://api:8000 (set automatically in docker-compose)
SERVER_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Data Source Configuration
# -----------------------------------------------------------------------------
SOURCE_HOST=api.simurg.space
SOURCE_PORT=443

# -----------------------------------------------------------------------------
# RabbitMQ Configuration
# -----------------------------------------------------------------------------
# For manual run with local RabbitMQ: localhost
# For manual run with Docker RabbitMQ: localhost
# For Docker deployment: rabbitmq (set automatically in docker-compose)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# MQTT Configuration (Currently not used, but available)
# -----------------------------------------------------------------------------
#MQTT_BROKER=your_mqtt_broker
#MQTT_PORT=1883
#MQTT_USERNAME=your_mqtt_username
#MQTT_PASSWORD=your_mqtt_password

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Path to store downloaded RINEX files
# For manual run: absolute path on your system (e.g., /home/user/rinex_data)
# For Docker: /var/rnx_streamer (set automatically, uses Docker volume)
STORAGE_PATH=/var/rnx_streamer

# How many days back to get data (e.g., 7 = get data from 7 days ago)
DAYS_TO_SUBTRACT=7

# Maximum RAM usage percentage before stopping adding new streamers
AVAILABLE_RAM=85
